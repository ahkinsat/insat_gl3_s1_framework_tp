@model TP.Models.MovieVM

@{
    ViewData["Title"] = "Edit Movie";
}

<div class="container mt-4">
    <h2>Edit Movie</h2>
    
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Movie.Id" />
                
                @if (ViewBag.Errors != null)
                {
                    <div class="alert alert-danger">
                        <ul class="mb-0">
                            @foreach (string error in ViewBag.Errors)
                            {
                                <li>@error</li>
                            }
                        </ul>
                    </div>
                }
                
                <div class="form-group mb-3">
                    <label asp-for="Movie.Name" class="control-label">Movie Name</label>
                    <input asp-for="Movie.Name" class="form-control" />
                    <span asp-validation-for="Movie.Name" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="Movie.DateTimeMovie" class="control-label">Release Date</label>
                    <input asp-for="Movie.DateTimeMovie" class="form-control" type="datetime-local" />
                    <span asp-validation-for="Movie.DateTimeMovie" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="Movie.GenreId" class="control-label">Genre</label>
                    <select asp-for="Movie.GenreId" class="form-control" asp-items="ViewBag.Genres">
                        <option value="">-- No Genre --</option>
                    </select>
                    <span asp-validation-for="Movie.GenreId" class="text-danger"></span>
                </div>
                
                @if (!string.IsNullOrEmpty(Model.Movie.ImageFile))
                {
                    <div class="form-group mb-3">
                        <label>Current Poster</label>
                        <div>
                            <img src="/images/@Model.Movie.ImageFile" alt="Movie poster" style="max-width: 200px; max-height: 200px;" class="img-thumbnail" />
                        </div>
                    </div>
                }
                
                <div class="form-group mb-3">
                    <label asp-for="Photo" class="control-label">New Poster (leave empty to keep current)</label>
                    <input asp-for="Photo" class="form-control" type="file" accept="image/*" />
                    <span asp-validation-for="Photo" class="text-danger"></span>
                </div>
                
                <div class="form-group">
                    <input type="submit" value="Save" class="btn btn-primary" />
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}