@model TP.Models.Movie

@{
    ViewData["Title"] = "Movie Details";
}

<div class="container mt-4">
    <h2>Movie Details</h2>
    
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                @if (!string.IsNullOrEmpty(Model.ImageFile))
                {
                    <img src="/images/@Model.ImageFile" class="card-img-top" alt="Movie poster" style="max-height: 400px; object-fit: cover;" />
                }
                else
                {
                    <img src="https://via.placeholder.com/400x200?text=No+Poster" class="card-img-top" alt="No poster available">
                }
                
                <div class="card-body">
                    <h5 class="card-title">@Model.Name</h5>
                    
                    <dl class="row">
                        @*
                        <dt class="col-sm-4">ID</dt>
                        <dd class="col-sm-8">@Model.Id</dd>
                        *@
                        
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@Model.Name</dd>
                        
                        <dt class="col-sm-4">Release Date</dt>
                        <dd class="col-sm-8">
                            @if (Model.DateTimeMovie != null)
                            {
                                @Model.DateTimeMovie.Value.ToString("MMMM dd, yyyy")
                            }
                            else
                            {
                                <span class="text-muted">Not specified</span>
                            }
                        </dd>
                        
                        <dt class="col-sm-4">Genre</dt>
                        <dd class="col-sm-8">
                            @if (Model.Genre != null)
                            {
                                @Model.Genre.Name
                            }
                            else
                            {
                                <span class="text-muted">No Genre</span>
                            }
                        </dd>
                        
                        @*
                        <dt class="col-sm-4">Poster</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrEmpty(Model.ImageFile))
                            {
                                <span>@Model.ImageFile</span>
                            }
                            else
                            {
                                <span class="text-muted">No poster</span>
                            }
                        </dd>
                        *@
                    </dl>
                    
                    <div class="mt-3">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
                        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>