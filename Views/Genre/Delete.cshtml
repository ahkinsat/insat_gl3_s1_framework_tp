@model TP.Models.Genre

@{
    ViewData["Title"] = "Delete Genre";
}

<div class="container mt-4">
    <h2>Delete Genre</h2>
    
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    
    <div class="alert alert-danger">
        <h3>Are you sure you want to delete this genre?</h3>
    </div>
    
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">
                            @Html.DisplayNameFor(model => model.Name)
                        </dt>
                        <dd class="col-sm-9">
                            @Html.DisplayFor(model => model.Name)
                        </dd>
                    </dl>
                    
                    @if (Model.Movies != null && Model.Movies.Any())
                    {
                        <div class="alert alert-warning">
                            <strong>Warning:</strong> This genre has @Model.Movies.Count() movie(s). 
                            Delete them first or reassign before deleting this genre.
                        </div>
                    }
                    
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <input type="submit" value="Delete" class="btn btn-danger" 
                               @(Model.Movies != null && Model.Movies.Any() ? "disabled" : "") />
                        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>