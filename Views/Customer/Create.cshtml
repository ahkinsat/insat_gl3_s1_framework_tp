@model TP.Models.Customer

@{
    ViewData["Title"] = "Create Customer";
}

<div class="container mt-4">
    <h2>Create Customer</h2>
    
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                @if (ViewBag.Errors != null)
                {
                    <div class="alert alert-danger">
                        <ul class="mb-0">
                            @foreach (string error in ViewBag.Errors)
                            {
                                <li>@error</li>
                            }
                        </ul>
                    </div>
                }

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="MembershipTypeId" class="control-label">Membership Type</label>
                    <select asp-for="MembershipTypeId" class="form-control" asp-items="ViewBag.MembershipTypes">
                        <option value="">-- No Membership --</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary" />
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}