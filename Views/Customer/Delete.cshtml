@model TP.Models.Customer

@{
    ViewData["Title"] = "Delete Customer";
}

<div class="container mt-4">
    <h2>Delete Customer</h2>
    
    <div class="alert alert-danger">
        <h3>Are you sure you want to delete this customer?</h3>
    </div>
    
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Name</dt>
                        <dd class="col-sm-9">@Model.Name</dd>
                        
                        <dt class="col-sm-3">Membership</dt>
                        <dd class="col-sm-9">
                            @if (Model.MembershipType != null)
                            {
                                @Model.MembershipType.Name
                            }
                            else
                            {
                                <span class="text-muted">No membership</span>
                            }
                        </dd>
                    </dl>
                    
                    @if (Model.Movies != null && Model.Movies.Any())
                    {
                        <div class="alert alert-warning">
                            <strong>Warning:</strong> This customer has @Model.Movies.Count() rented movie(s).
                        </div>
                    }
                    
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <input type="submit" value="Delete" class="btn btn-danger" />
                        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>