@model IEnumerable<TP.Models.UserCart>

@{
    ViewData["Title"] = "My Cart";
}

<div class="container mt-4">
    <h2>My Cart</h2>
    
    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Your cart is empty. <a asp-controller="Movie" asp-action="Index">Browse movies</a>
        </div>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Movie</th>
                    <th>Quantity</th>
                    <th>Added Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Movie?.Name</td>
                        <td>@item.Quantity</td>
                        <td>@item.AddedDate.ToString("MMM dd, yyyy")</td>
                        <td>
                            <form asp-action="RemoveFromCart" method="post" style="display: inline;">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>